# Luna Fund — cp .env.example .env

# Database (docker compose)
DATABASE_URL=postgresql+asyncpg://luna:luna@localhost:5433/luna_fund
DATABASE_URL_SYNC=postgresql+psycopg://luna:luna@localhost:5433/luna_fund

# Chat LLM (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95
LLM_MAX_TOKENS=1024

# Embeddings (empty key → reuse OPENAI_API_KEY)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
# Optional forward-proxy for embedding calls only (e.g. provider geo-blocked
# from the host). Empty = direct. Example: http://127.0.0.1:10809
EMBEDDING_PROXY=

# Google Sheets (link-viewable / public)
GOOGLE_SHEETS_SPREADSHEET_ID=
SHEETS_FUND_PRICE_RANGE=Fund!B2

# CoinStats portfolio (share link — DevTools headers)
COINSTATS_SHARE_TOKEN=
COINSTATS_UUID=

# Background sync (API process)
SYNC_ENABLED=true
SYNC_RUN_ON_STARTUP=true
SYNC_SHEETS_INTERVAL_MINUTES=15
SYNC_PORTFOLIO_INTERVAL_MINUTES=30

CONTENT_RESEARCH_DIR=./content/research
ADMIN_SECRET=change-me

# LangSmith (optional)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGSMITH_PROJECT=luna-fund

# Streamlit portal (optional)
# LUNA_API_URL=http://127.0.0.1:8000
